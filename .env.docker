# ─── Docker / Coolify Deployment Environment ─────────────────────────────────
# Copy this file to .env and fill in your values before deploying

# PostgreSQL
POSTGRES_USER=testsgen
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=testsgen

# Database URL (auto-constructed from the above in docker-compose)
DATABASE_URL=postgresql://testsgen:change_this_strong_password@postgres:5432/testsgen

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=change_this_to_a_secure_random_string_32chars
NEXTAUTH_URL=https://your-domain.com
AUTH_SECRET=change_this_to_a_secure_random_string_32chars

# AI Provider — OpenRouter (recommended)
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-...
AI_MODEL_GENERATION=google/gemini-2.0-flash-001
AI_MODEL_GRADING=google/gemini-2.0-flash-001

# Alternative providers (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# App Port (default 3000)
APP_PORT=3000
