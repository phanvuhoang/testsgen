// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum SessionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum FileType {
  SYLLABUS
  TAX_REGULATIONS
  SAMPLE_QUESTIONS
  STUDY_MATERIAL
  RATES_TARIFF
  OTHER
}

enum QuestionType {
  MCQ_SINGLE
  MCQ_MULTIPLE
  SCENARIO
  ESSAY
  SHORT_ANSWER
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionStatus {
  APPROVED
  NEEDS_REVIEW
}

enum MockExamStatus {
  DRAFT
  PUBLISHED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum QuizSetStatus {
  DRAFT
  OPEN
  CLOSED
}

enum QuizQuestionType {
  MCQ
  MULTIPLE_RESPONSE
  TRUE_FALSE
  SHORT_ANSWER
  FILL_BLANK
  ESSAY
  MATCHING
  TEXT_BLOCK          // non-interactive instruction/header block
  LONG_ANSWER         // ungraded long answer
}

enum IdentifyBy {
  NAME
  EMAIL
  ID
}

enum QuizAccess {
  PUBLIC
  PASSCODE
  EMAIL_LIST
}

enum DisplayMode {
  ALL_AT_ONCE
  ONE_AT_ONCE
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id          String     @id @default(cuid())
  name        String
  email       String     @unique
  password    String
  role        UserRole   @default(STUDENT)
  status      UserStatus @default(ACTIVE)
  lastLoginAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  projects         Project[]
  quizSets         QuizSet[]
  attempts         Attempt[]
  gameshowSessions GameshowSession[] @relation("GameshowHost")
  gameshowPlayers  GameshowPlayer[]  @relation("GameshowPlayers")

  @@map("testsgen_users")
}

model Project {
  id           String        @id @default(cuid())
  name         String
  code         String        @unique
  description  String?
  status       ProjectStatus @default(ACTIVE)
  createdById  String
  parsePattern String?       @default("HEADING2_EXAMPLE")  // Parse pattern: HEADING2_EXAMPLE | NUMBERED_LIST | AI_ONLY
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  createdBy User      @relation(fields: [createdById], references: [id])
  sessions  Session[]

  @@map("testsgen_projects")
}

model Session {
  id        String        @id @default(cuid())
  projectId String
  name      String
  status    SessionStatus @default(DRAFT)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relations
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documents        Document[]
  topics           Topic[]
  sections         ExamSection[]
  questions        Question[]
  mockExams        MockExam[]
  parsedQuestions  ParsedQuestion[]
  generateJobs     GenerateJob[]
  sessionVariables SessionVariable[]

  @@map("testsgen_sessions")
}

model Document {
  id          String   @id @default(cuid())
  sessionId   String
  fileName    String
  fileType    FileType @default(OTHER)
  fileSize    Int
  filePath    String
  uploadedAt  DateTime @default(now())
  description String?  // For OTHER type: what is this document?
  topicId     String?  // Optional: link to a Topic
  topicName   String?  // Denormalized topic name for display
  sectionId   String?  // Optional: link to an ExamSection
  sectionName String?  // Denormalized section name for display
  isManualInput Boolean  @default(false) // true = content pasted manually, not uploaded
  content       String?  // manual input text content
  topicIds     String?  // JSON array of topic IDs ["id1","id2"]
  topicNames   String?  // JSON array of topic names ["CIT","PIT"]
  sectionIds   String?  // JSON array of section IDs
  sectionNames String?  // JSON array of section names

  // Relations
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("testsgen_documents")
}

model ParsedQuestion {
  id           String   @id @default(cuid())
  sessionId    String
  documentId   String?  // null = manually created
  title        String?
  content      String   // Full question text
  answer       String?  // Answer/explanation
  questionType String   @default("MCQ_SINGLE")
  topicId      String?
  topicName    String?
  sectionId    String?
  sectionName  String?
  syllabusCode String?
  difficulty   String   @default("MEDIUM")
  sortOrder    Int      @default(0)
  isManual     Boolean  @default(false)
  createdAt    DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("testsgen_parsed_questions")
}

model GenerateJob {
  id           String   @id @default(cuid())
  sessionId    String
  status       String   @default("PENDING")   // PENDING | RUNNING | DONE | FAILED
  config       String                          // JSON: full generate config
  progress     Int      @default(0)            // questions generated so far
  total        Int      @default(0)            // total questions to generate
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("testsgen_generate_jobs")
}

model SessionVariable {
  id          String   @id @default(cuid())
  sessionId   String
  varKey      String
  varLabel    String
  varValue    String
  varUnit     String?
  description String?
  createdAt   DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("testsgen_session_variables")
}

model Topic {
  id          String   @id @default(cuid())
  sessionId   String
  name        String
  description String?
  sortOrder   Int      @default(0)
  isOverall   Boolean  @default(false)  // true = this is the "Overall Topic" for the session
  parentId    String?  // null = root topic; set = sub-topic of parentId
  createdAt   DateTime @default(now())

  // Relations
  session  Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  parent   Topic?   @relation("TopicChildren", fields: [parentId], references: [id])
  children Topic[]  @relation("TopicChildren")

  @@map("testsgen_topics")
}

model ExamSection {
  id                 String       @id @default(cuid())
  sessionId          String
  name               String
  instructions       String?
  questionType       QuestionType @default(MCQ_SINGLE)
  marksPerQuestion   Int          @default(1)
  questionsInExam    Int          @default(10)
  questionsInBank    Int          @default(40)
  topics             String?
  aiInstructions     String?
  sortOrder          Int          @default(0)
  questionTypes      String?   // JSON: [{type: string, count: number, marksEach: number}]
  topicBreakdown     String?   // JSON: [{topicId?: string, topicName: string, count: number}]

  // Relations
  session          Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questions        Question[]
  mockExamSections MockExamSection[]

  @@map("testsgen_sections")
}

model Question {
  id            String         @id @default(cuid())
  sessionId     String
  sectionId     String
  stem          String
  options       Json?
  correctAnswer String?
  markingScheme String?
  modelAnswer   String?
  topic         String?
  difficulty    Difficulty     @default(MEDIUM)
  status        QuestionStatus @default(NEEDS_REVIEW)
  questionType  QuestionType   @default(MCQ_SINGLE)
  marks         Int            @default(1)
  createdAt     DateTime       @default(now())

  // Relations
  session         Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  section         ExamSection       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  attemptAnswers  AttemptAnswer[]

  @@map("testsgen_questions")
}

model MockExam {
  id                  String         @id @default(cuid())
  sessionId           String
  name                String
  duration            Int            // minutes
  instructions        String?
  passMark            Int            @default(50) // percentage
  passMessage         String?
  failMessage         String?
  status              MockExamStatus @default(DRAFT)
  allowSequentialOnly Boolean        @default(false)
  createdAt           DateTime       @default(now())

  // Relations
  session  Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sections MockExamSection[]
  attempts Attempt[]

  @@map("testsgen_mock_exams")
}

model MockExamSection {
  id                  String @id @default(cuid())
  mockExamId          String
  sectionId           String
  questionsToDrawCount Int    @default(5)

  // Relations
  mockExam MockExam    @relation(fields: [mockExamId], references: [id], onDelete: Cascade)
  section  ExamSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("testsgen_mock_exam_sections")
}

model Attempt {
  id                String        @id @default(cuid())
  userId            String?
  mockExamId        String?
  quizSetId         String?
  variantId         String?       // null = no variant (uses parent quiz)
  startedAt         DateTime      @default(now())
  submittedAt       DateTime?
  totalScore        Float?
  maxScore          Float?
  status            AttemptStatus @default(IN_PROGRESS)
  guestName         String?
  guestEmail        String?
  questionsSnapshot Json?         // snapshot of questions at time of attempt

  quizClassId     String?
  quizClass       QuizClass?     @relation("ClassAttempts", fields: [quizClassId], references: [id])

  // Relations
  user     User?          @relation(fields: [userId], references: [id])
  mockExam MockExam?      @relation(fields: [mockExamId], references: [id])
  quizSet  QuizSet?       @relation(fields: [quizSetId], references: [id])
  variant  QuizVariant?   @relation(fields: [variantId], references: [id])
  answers  AttemptAnswer[]

  @@map("testsgen_attempts")
}

model AttemptAnswer {
  id           String    @id @default(cuid())
  attemptId    String
  questionId   String?
  quizQuestionId String?
  answer       String?
  isCorrect    Boolean?
  marksAwarded Float?
  aiFeedback   String?
  gradedAt     DateTime?

  // Relations
  attempt      Attempt       @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question     Question?     @relation(fields: [questionId], references: [id])
  quizQuestion QuizQuestion? @relation(fields: [quizQuestionId], references: [id])

  @@unique([attemptId, quizQuestionId])
  @@unique([attemptId, questionId])
  @@map("testsgen_attempt_answers")
}

model QuizSet {
  id                  String        @id @default(cuid())
  title               String
  description         String?
  createdById         String
  shareCode           String        @unique @default(cuid())
  status              QuizSetStatus @default(DRAFT)
  questionsPerAttempt Int           @default(20)
  timeLimitMinutes    Int?
  showAnswers         Boolean       @default(true)
  passMark            Int           @default(50)
  maxAttempts         Int?
  identifyBy          IdentifyBy    @default(EMAIL)
  access              QuizAccess    @default(PUBLIC)
  passcode            String?
  allowedEmails       String?       // JSON array of emails
  randomizeQuestions  Boolean       @default(true)
  displayMode         DisplayMode   @default(ONE_AT_ONCE)
  disablePrevButton   Boolean       @default(false)
  requireLogin        Boolean       @default(false)
  expiresAt           DateTime?
  tags                Json?         @default("[]")
  theme               String?       @default("default")
  themeColor          String?       @default("#028a39")  // primary accent color
  themeFont           String?       @default("Inter")    // font family
  themeLogo           String?                             // URL/path to custom logo
  passMessage         String?
  failMessage         String?
  introText           String?       // Introduction shown before test starts
  conclusionText      String?       // Text shown after submission
  certificateEnabled      Boolean @default(false)
  certificateTitle        String? @default("Certificate of Completion")
  certificateMessage      String?
  certificateBorderColor  String? @default("#028a39")
  certificateFont         String? @default("Georgia")
  certificateShowLogo     Boolean @default(true)
  certificateShowScore    Boolean @default(true)
  certificateShowDate     Boolean @default(true)
  certificateIssuerName   String?
  certificateIssuerTitle  String?
  // Difficulty mix settings
  easyPercent         Int           @default(20)
  mediumPercent       Int           @default(60)
  hardPercent         Int           @default(20)
  // Question selection mix (optional override)
  easyCount             Int?
  mediumCount           Int?
  hardCount             Int?
  questionTypeMix       String?   // JSON: {type: count, ...}
  filterTopics          String?   // JSON: string[] of topics to include
  filterTags            String?   // JSON: string[] of tags to include
  // Testmoz-parity settings
  allowBlankAnswers        Boolean       @default(false)
  penalizeIncorrect        Boolean       @default(false)
  partialCredits           Boolean       @default(false) // For MULTIPLE_RESPONSE: award partial points per correct selection
  showScore           Boolean       @default(true)
  showOutline         Boolean       @default(true)
  showCorrectAnswers  Boolean       @default(true)
  // Per-question feedback (shown immediately after each question is answered)
  feedbackShowCorrect Boolean       @default(false)  // indicate correct/incorrect
  feedbackShowAnswer  Boolean       @default(false)  // display the correct answer
  feedbackShowExplanation Boolean   @default(false)  // show explanation
  notificationEmail   String?       // comma-separated emails for completion notifications
  disableRightClick   Boolean       @default(false)
  disableCopyPaste    Boolean       @default(false)
  disableTranslate    Boolean       @default(false)
  disablePrint        Boolean       @default(false)
  customIdentifierPrompt String?    // custom text above name/ID field
  language            String?       @default("en") // "en" or "vi"
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  createdBy   User           @relation(fields: [createdById], references: [id])
  questions   QuizQuestion[]
  attempts    Attempt[]
  documents   QuizDocument[]
  variants    QuizVariant[]
  classes     QuizClass[]    @relation("QuizSetClasses")
  gameshows   Gameshow[]     @relation("QuizSetGameshows")

  @@map("testsgen_quiz_sets")
}

model QuizDocument {
  id         String   @id @default(cuid())
  quizSetId  String
  fileName   String
  fileType   String   @default("other")
  fileSize   Int
  filePath   String
  uploadedAt DateTime @default(now())

  // Relations
  quizSet QuizSet @relation(fields: [quizSetId], references: [id], onDelete: Cascade)

  @@map("testsgen_quiz_documents")
}

model QuizQuestion {
  id            String           @id @default(cuid())
  quizSetId     String
  stem          String
  questionType  QuizQuestionType @default(MCQ)
  options       Json?            // For MCQ/MULTIPLE_RESPONSE: string[]; For MATCHING: {left: string[], right: string[]}
  correctAnswer String?          // For MCQ: string; For MULTIPLE_RESPONSE: "||" delimited; For MATCHING: "left||right" pairs
  explanation   String?
  difficulty    Difficulty       @default(MEDIUM)
  points        Int              @default(1)
  sortOrder     Int              @default(0)  // for numbering/ordering
  poolTag       String?          // question pool tag (e.g. "Pool A")
  topic         String?          // e.g. "Algebra", "World War II"
  tags          String?          // comma-separated tags e.g. "math,equations,grade10"
  createdAt     DateTime         @default(now())

  // Relations
  quizSet        QuizSet         @relation(fields: [quizSetId], references: [id], onDelete: Cascade)
  attemptAnswers AttemptAnswer[]

  @@map("testsgen_quiz_questions")
}

model QuizVariant {
  id                  String        @id @default(cuid())
  quizSetId           String
  name                String        // e.g. "Variant A", "Hard Mode"
  description         String?
  // Override quiz settings per variant
  questionsPerAttempt Int?
  timeLimitMinutes    Int?
  passMark            Int?
  randomizeQuestions  Boolean?      // null = inherit from parent
  displayMode         DisplayMode?
  questionFilter      String?       // JSON: { poolTags?: string[], difficulty?: string, maxQuestions?: number }
  shareCode           String        @unique @default(cuid())  // unique URL for this variant
  shuffleAnswerOptions Boolean      @default(false)    // shuffle answer option order per student
  fixedQuestionIds    String?       // JSON: string[] of specific question IDs to always use
  disablePrevButton   Boolean       @default(false)
  requireLogin        Boolean?      // null = inherit from parent
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  quizSet  QuizSet   @relation(fields: [quizSetId], references: [id], onDelete: Cascade)
  attempts Attempt[]

  @@map("testsgen_quiz_variants")
}

model QuizClass {
  id              String   @id @default(cuid())
  name            String
  description     String?
  shareCode       String   @unique @default(cuid())
  
  // Parent quiz set
  quizSetId       String
  quizSet         QuizSet  @relation("QuizSetClasses", fields: [quizSetId], references: [id], onDelete: Cascade)
  
  // Settings (override parent)
  timeLimitMinutes      Int?
  questionsPerAttempt   Int?
  passMark              Int?
  randomizeQuestions    Boolean   @default(true)
  shuffleAnswerOptions  Boolean   @default(false)
  disablePrevButton     Boolean   @default(false)
  displayMode           String?   @default("ONE_AT_ONCE")
  requireLogin          Boolean   @default(false)
  maxAttempts           Int?
  
  // Fixed question set (JSON array of question IDs)
  // null = use all questions from parent (with randomization/pool settings)
  fixedQuestionIds      String?
  
  // Feedback settings
  feedbackShowCorrect   Boolean   @default(false)
  feedbackShowAnswer    Boolean   @default(false)
  feedbackShowExplanation Boolean @default(false)
  passMessage           String?
  failMessage           String?

  // Content
  introText             String?
  conclusionText        String?

  // Access
  accessType            String?   @default("PUBLIC")
  passcode              String?

  // Certificate
  certificateEnabled    Boolean   @default(false)
  certificateTitle      String?   @default("Certificate of Completion")
  certificateMessage    String?
  certificateBorderColor String?  @default("#028a39")
  certificateFont       String?   @default("Georgia")
  certificateShowScore  Boolean   @default(true)
  certificateShowDate   Boolean   @default(true)
  certificateIssuerName String?
  certificateIssuerTitle String?

  // Question difficulty/type mix (Fix 4)
  easyCount             Int?
  mediumCount           Int?
  hardCount             Int?
  questionTypeMix       String?   // JSON: {type: count, ...}
  filterTopics          String?   // JSON: string[] of topics to include
  filterTags            String?   // JSON: string[] of tags to include

  // Results display settings (override quizSet)
  showAnswers           Boolean   @default(true)
  showScore             Boolean   @default(true)
  showCorrectAnswers    Boolean   @default(true)

  // Email settings
  autoSendResults       Boolean   @default(false)
  autoSendResultType    String?   @default("comprehensive")

  attempts        Attempt[]   @relation("ClassAttempts")
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("testsgen_quiz_classes")
}

// ─────────────────────────────────────────────────────────────────────────────
// GAMESHOW MODULE
// ─────────────────────────────────────────────────────────────────────────────

// GameshowType: style of gameshow
enum GameshowType {
  WWTBAM
  KAHOOT
  JEOPARDY
}

// PlayMode: who is playing
enum GameshowPlayMode {
  SINGLE      // Solo player
  LOCAL       // Multiple players, same device
  ONLINE      // Real-time multiplayer via different devices
}

// SelectionMode: question ordering
enum GameshowSelectionMode {
  LINEAR      // Sequential Q1 → Q2 → Q3
  FREE_CHOICE // Player/Host chooses next question
}

// ScoringMode
enum GameshowScoringMode {
  SPEED_ACCURACY  // Correct + fast = more points
  ACCURACY_ONLY   // Correct answer = flat points, speed ignored
}

// GameshowSession status
enum GameshowSessionStatus {
  WAITING   // Room created, waiting for players
  ACTIVE    // Game in progress
  FINISHED  // Game ended
}

model Gameshow {
  id            String        @id @default(cuid())
  name          String
  description   String?
  shareCode     String        @unique @default(cuid())

  // Parent quiz set
  quizSetId     String
  quizSet       QuizSet       @relation("QuizSetGameshows", fields: [quizSetId], references: [id], onDelete: Cascade)

  // Game configuration
  type          GameshowType  @default(KAHOOT)
  playMode      GameshowPlayMode @default(SINGLE)
  selectionMode GameshowSelectionMode @default(LINEAR)
  scoringMode   GameshowScoringMode  @default(SPEED_ACCURACY)

  // Question settings
  questionsCount    Int?       // How many questions to use (null = all)
  fixedQuestionIds  String?    // JSON array of question IDs (null = use all/random)
  easyCount         Int?
  mediumCount       Int?
  hardCount         Int?
  shuffleQuestions  Boolean    @default(true)
  showLeaderboard   Boolean    @default(true)
  clickStartToCount Boolean    @default(false)
  buzzerMode        Boolean    @default(false)  // Online: players buzz in to answer
  manualScoring     Boolean    @default(false)  // Local: host manually adjusts scores after each question
  shortLink         String?    // Custom short URL for the gameshow

  // Timer settings
  timeLimitSeconds  Int        @default(30)   // Per-question timer
  answerRevealSeconds Int      @default(4)    // Time to view answer before responding (Jeopardy)
  responseSeconds   Int        @default(10)   // Time to respond after buzz

  // WWTBAM lifelines
  enableLifelines   Boolean    @default(true)
  lifelines         String?    // JSON array e.g. ["5050","phone","audience"]

  // Kahoot-specific
  enableStreak      Boolean    @default(true)
  streakBonus       Int        @default(50)   // pts per consecutive correct

  // Jeopardy-specific
  categoriesCount   Int        @default(5)
  tiersPerCategory  Int        @default(5)
  // Point values per tier: JSON array e.g. [10,25,50,100,200]
  tierPoints        String?    // JSON array e.g. "[10,25,50,100,200]"
  categoryNames     String?    // JSON array e.g. ["CIT", "PIT", "VAT", "TP", "Other"]
  jeopardyTags      String?    // JSON: {questionId: {category: number, tier: number}}

  // Multiplayer settings
  maxPlayers        Int        @default(4)
  requireLogin      Boolean    @default(false)

  // Access
  accessType        String?    @default("PUBLIC")
  passcode          String?

  sessions          GameshowSession[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@map("testsgen_gameshows")
}

model GameshowSession {
  id            String              @id @default(cuid())
  roomCode      String              @unique
  status        GameshowSessionStatus @default(WAITING)

  gameshowId    String
  gameshow      Gameshow            @relation(fields: [gameshowId], references: [id], onDelete: Cascade)

  // Host user (null = anonymous)
  hostId        String?
  host          User?               @relation("GameshowHost", fields: [hostId], references: [id])

  // Current game state (JSON)
  // Stores: currentQuestionIndex, questionOrder[], startedAt, finishedAt, etc.
  gameState     String?             // JSON

  players       GameshowPlayer[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("testsgen_gameshow_sessions")
}

model GameshowPlayer {
  id            String   @id @default(cuid())
  sessionId     String
  session       GameshowSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Player identity (may be anonymous)
  userId        String?
  user          User?    @relation("GameshowPlayers", fields: [userId], references: [id])
  nickname      String
  avatarColor   String?  @default("#028a39")

  // Score tracking
  score         Int      @default(0)
  correctCount  Int      @default(0)
  wrongCount    Int      @default(0)
  streak        Int      @default(0)  // Current consecutive correct streak
  bestStreak    Int      @default(0)

  // Answers (JSON array of {questionId, answer, correct, pointsEarned, responseTimeMs})
  answers       String?  // JSON

  // Connection status
  isConnected   Boolean  @default(true)
  lastSeenAt    DateTime @default(now())

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("testsgen_gameshow_players")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("testsgen_system_settings")
}
