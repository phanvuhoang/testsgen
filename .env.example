# Database — external PostgreSQL on VPS
# Format Prisma (Node.js): postgresql://user:password@host:port/database
# NOTE: Khác với Python/SQLAlchemy dùng postgresql+asyncpg:// — Prisma chỉ dùng postgresql://
DATABASE_URL="postgresql://legaldb_user:your_password@10.0.1.11:5432/testsgen"

# Auth
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-domain.com"
AUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"

# AI Providers
# Choose ONE as active provider: anthropic | openai | deepseek | openrouter
AI_PROVIDER=deepseek

# Provider API keys (set these in Coolify environment variables — do NOT commit real keys)
DEEPSEEK_API_KEY=your-deepseek-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=

# Model to use for question generation and grading (default: deepseek-v4-pro)
# This value is read by server-side AI calls and seeded into system_settings on first start.
AI_MODEL_GENERATION=deepseek-v4-pro
AI_MODEL_GRADING=deepseek-v4-pro

# OpenRouter models (selectable in admin UI)
OPENROUTER_MODEL1=xiaomi/mimo-v2-pro
OPENROUTER_MODEL2=qwen/qwen3-plus

# Storage
UPLOAD_DIR="./public/uploads"

# Email (optional — for sending results feedback)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@testsgen.com

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=TestsGen
