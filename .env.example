# Database — external PostgreSQL on VPS
# Format Prisma (Node.js): postgresql://user:password@host:port/database
# NOTE: Khác với Python/SQLAlchemy dùng postgresql+asyncpg:// — Prisma chỉ dùng postgresql://
DATABASE_URL="postgresql://legaldb_user:your_password@10.0.1.11:5432/testsgen"

# Auth
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-domain.com"
AUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"

# AI Providers
# Choose ONE as active provider: anthropic | openai | deepseek | openrouter
AI_PROVIDER=openrouter

# Provider API keys (only the active one is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# If using OpenRouter, specify which models to use (up to 5, comma-separated)
OPENROUTER_MODELS=google/gemini-2.0-flash-001,anthropic/claude-3.5-haiku,meta-llama/llama-3.3-70b-instruct,deepseek/deepseek-chat-v3-0324,mistralai/mistral-small-3.1-24b-instruct

# Model to use for question generation (defaults shown)
AI_MODEL_GENERATION=google/gemini-2.0-flash-001
# Model to use for grading written answers
AI_MODEL_GRADING=google/gemini-2.0-flash-001

# Storage
UPLOAD_DIR="./public/uploads"

# Email (optional — for sending results feedback)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@testsgen.com

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=TestsGen
